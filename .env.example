# API base URL (no trailing slash). Used at BUILD time — set this before running npm run build.
# Local dev (backend on port 5000):
# VITE_API_BASE_URL=http://localhost:5000/api/v1
# Production (your server):
# VITE_API_BASE_URL=https://your-server.com/api/v1
VITE_API_BASE_URL=http://localhost:5000/api/v1
